# =============================================
# JP Style Lounge Studio - Example Environment
# Client-safe values only. Do not put server API keys here.
# =============================================

# Core
APP_ENV=production
FREE_MODE=false

# Feature toggles
ENABLE_PAYMENTS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_MAPS=true
MOCK_PAYMENT_SUCCESS=false

# Appwrite (client/public config)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=YOUR_APPWRITE_PROJECT_ID
APPWRITE_DATABASE_ID=jp_style_lounge_prod

# Appwrite collection IDs
APPWRITE_USERS_COLLECTION_ID=users
APPWRITE_BARBERS_COLLECTION_ID=barbers
APPWRITE_SERVICES_COLLECTION_ID=services
APPWRITE_SERVICE_ADDONS_COLLECTION_ID=service_addons
APPWRITE_AVAILABILITY_COLLECTION_ID=availability
APPWRITE_BOOKINGS_COLLECTION_ID=bookings
APPWRITE_BOOKING_ADDONS_COLLECTION_ID=booking_addons
APPWRITE_PAYMENTS_COLLECTION_ID=payments
APPWRITE_REVIEWS_COLLECTION_ID=reviews
APPWRITE_BARBER_SETTINGS_COLLECTION_ID=barber_settings

# Appwrite storage bucket IDs
APPWRITE_PORTFOLIO_BUCKET_ID=portfolio
APPWRITE_REFERENCE_PHOTOS_BUCKET_ID=reference_photos
APPWRITE_SERVICE_IMAGES_BUCKET_ID=service_images
APPWRITE_REVIEW_PHOTOS_BUCKET_ID=review_photos

# Firebase (FCM public project identifier)
FIREBASE_PROJECT_ID=jp-style-lounge-studio

# Google Maps (restricted client key)
GOOGLE_MAPS_API_KEY=YOUR_RESTRICTED_MAPS_KEY

# Paystack (public key only; secret/webhook keys belong on the backend)
PAYSTACK_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY

# Backend-only values such as APPWRITE_API_KEY, PAYSTACK_SECRET_KEY,
# PAYSTACK_WEBHOOK_SECRET, and AFRICAS_TALKING_API_KEY must stay in server
# environments or local setup files that are never bundled into Flutter.
